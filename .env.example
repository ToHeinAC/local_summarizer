# Copy to .env and adjust. Loaded via python-dotenv.

# Ollama server (langchain-ollama reads this base URL).
OLLAMA_HOST=http://localhost:11434

# Streamlit port for this app.
APP_PORT=8530

# Defaults (must match ids in src/models.py and src/templates.py).
DEFAULT_MODEL=standard
DEFAULT_TEMPLATE=standard
DEFAULT_LANGUAGE=auto

# Markdown conversion (src/md_convert.py).
# OCR_MODEL must be vision-capable; it reads scanned PDF pages.
OCR_MODEL=deepseek-ocr:3b
# REWRITE_MODEL reformats digital PDF text as Markdown (wording preserved).
REWRITE_MODEL=gemma4:e4b
# Rasterization resolution for scanned pages.
PDF_DPI=150
