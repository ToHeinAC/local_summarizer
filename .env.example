# Copy to .env and adjust. Loaded via python-dotenv.

# Ollama server (langchain-ollama reads this base URL).
OLLAMA_HOST=http://localhost:11434

# Streamlit port for this app.
APP_PORT=8506

# Defaults (must match ids in src/models.py and src/templates.py).
DEFAULT_MODEL=standard
DEFAULT_TEMPLATE=standard
DEFAULT_LANGUAGE=auto
